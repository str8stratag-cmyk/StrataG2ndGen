# StrataG2ndGen Backend Environment Variables

# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# Database (PostgreSQL)
# Railway: postgresql://postgres:PASSWORD@HOST:PORT/railway
# Neon: postgresql://user:password@host.neon.tech/dbname
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-host:5432/your-db

# Admin Credentials
ADMIN_EMAIL=admin@stratag.tech
ADMIN_PASSWORD=your-secure-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Vonage (SMS + WhatsApp)
# Sign up at https://developer.vonage.com/
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_FROM_NUMBER=14157386102
VONAGE_FROM_WHATSAPP=14157386102

# Google Gemini (Audio Transcription + AI Analysis — FREE!)
# Get API key at https://aistudio.google.com/app/apikey (1500 requests/day free tier)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
